# ============================================================
# ProtectMe AI — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the real values:
#     Windows:      copy .env.example .env
#     macOS/Linux:  cp .env.example .env
#
# NEVER commit the real .env file (it is gitignored).
#
# Tip: run `python -m app.utils.model_check` to list the Gemini
# model IDs available for your API key before setting the model
# variables below.
# ============================================================

# ── Google AI Studio (Gemini) ─────────────────────────────
# Get a key at https://aistudio.google.com/app/apikey  (starts with "AIza...")
GEMINI_API_KEY=

# Analysis model — used to analyze the contract (long context, JSON output).
# Example: gemini-2.5-pro  or  gemini-1.5-pro-latest
GEMINI_ANALYSIS_MODEL=gemini-2.5-pro

# Conversation model — used by the voice agent, intent routing, fast replies.
# Example: gemini-2.5-flash  or  gemini-1.5-flash-latest
GEMINI_CONVERSATION_MODEL=gemini-2.5-flash

# Voice fallback model — fastest model for SHORT spoken fallback answers
# (used only when a question can't be answered from the report directly).
VOICE_FALLBACK_MODEL=gemini-2.5-flash-lite

# Live model — EXPERIMENTAL Gemini Live native audio (NOT used by default).
# The demo runs on Journey TTS; only set/needed if you flip the frontend to live.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest

# ── Google Cloud Text-to-Speech (Journey voice — primary demo audio) ──
# TTS provider: google_cloud (Journey, ~300ms) | gemini (Charon, slower fallback)
TTS_PROVIDER=google_cloud

# Path to the Google Cloud service-account JSON, RELATIVE to the backend/ folder.
# Place the file at:  backend/.secrets/google-tts-service-account.json
# The .secrets/ directory is gitignored — NEVER commit the JSON file.
GOOGLE_APPLICATION_CREDENTIALS=.secrets/google-tts-service-account.json

# Journey voice — warm, calm, professional male (en-US)
GOOGLE_CLOUD_TTS_VOICE=en-US-Journey-D
GOOGLE_CLOUD_TTS_LANGUAGE=en-US

# Arabic voice (Phase 8H) — used automatically when the answer is in Arabic.
# Verified available ar-XA voice (male, WaveNet). Leave blank to let Google pick
# a default ar-XA voice (a one-time fallback warning is logged).
# Discover all options:  python -m app.utils.list_voices ar
GOOGLE_CLOUD_TTS_ARABIC_VOICE=ar-XA-Wavenet-B
GOOGLE_CLOUD_TTS_ARABIC_LANGUAGE=ar-XA

# Per-chunk TTS timeout (seconds). If one chunk stalls, the turn shows text
# instead and keeps going — it never blocks the whole voice response.
TTS_CHUNK_TIMEOUT_SECONDS=8

# Legacy Google Cloud TTS REST API key (unused when a service account is set).
GOOGLE_CLOUD_TTS_API_KEY=

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. http://localhost:3000 is
# always allowed for local dev even if this is left blank.
BACKEND_CORS_ORIGINS=http://localhost:3000
# (Legacy single-origin variable — still honored if BACKEND_CORS_ORIGINS is unset.)
FRONTEND_URL=http://localhost:3000

# ── Application ───────────────────────────────────────────
APP_NAME=ProtectMe AI
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ── Session management ────────────────────────────────────
# How long (minutes) an idle in-memory session is kept before cleanup.
SESSION_TTL_MINUTES=60
