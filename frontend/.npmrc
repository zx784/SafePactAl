# If npm install fails on a network drive (EBADF), install from a local directory:
#   mkdir C:\temp\pm-install
#   copy package.json C:\temp\pm-install\
#   cd C:\temp\pm-install && npm install
#   robocopy node_modules ..\protectme-ai-agent\frontend\node_modules /E /MT:8
fetch-retries=5
fetch-retry-mintimeout=5000
