# ============================================================
# ProtectMe AI — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local and adjust if needed:
#     Windows:      copy .env.example .env.local
#     macOS/Linux:  cp .env.example .env.local
#
# All NEXT_PUBLIC_* values are exposed to the browser (they are NOT secrets).
# Next.js bakes these at build/startup — RESTART `npm run dev` after changing.
# NEVER commit .env.local (it is gitignored).
# ============================================================

# Backend REST API base URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Backend WebSocket base URL (voice agent). If omitted, it is derived from
# NEXT_PUBLIC_API_BASE_URL by swapping http -> ws.
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8001

# Voice mode:
#   tts  -> Google Cloud Journey TTS pipeline   (DEFAULT — stable demo voice)
#   live -> Gemini Live native audio            (EXPERIMENTAL — do not use unless asked)
NEXT_PUBLIC_VOICE_MODE=tts

# (Live mode only) seconds before a silent Live turn falls back to Journey TTS.
# The first turn can be a cold start, so it gets a longer grace window.
NEXT_PUBLIC_LIVE_FIRST_TURN_TIMEOUT_SECONDS=8
NEXT_PUBLIC_LIVE_TURN_TIMEOUT_SECONDS=5
